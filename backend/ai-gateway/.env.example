# ─────────────────────────────────────────────────────────────────────────────
# Suklu AI Gateway — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# LLM provider — "openai" | "gemini"
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Google Gemini (used when LLM_PROVIDER=gemini)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Qdrant vector database
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=suklu_curriculum

# Firebase (AI Gateway service account — grants Firestore write for AI logs)
FIREBASE_SERVICE_ACCOUNT_PATH=/secrets/firebase-service-account.json
GCP_PROJECT_ID=suklu-prod

# Safety filter
CONTENT_MODERATION_ENABLED=true
# Minimum age of users the platform serves (affects content filtering strictness)
MIN_USER_AGE=8

# Embedding chunk size (tokens)
CHUNK_SIZE=512
CHUNK_OVERLAP=64

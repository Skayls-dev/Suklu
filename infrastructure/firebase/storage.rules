rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Authenticated users can read/write their own files
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    // Tutor documents readable by admin roles
    match /tutor_documents/{allPaths=**} {
      allow read: if request.auth != null
        && request.auth.token.role in ['super_admin', 'academic_staff'];
      allow write: if request.auth != null;
    }
    // Session recordings readable by participants
    match /sessions/{sessionId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
